    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
    <style>
        :root {
            --sys-bg: #030508;
            --sys-cyan: #00e5ff;
            --sys-cyan-dim: rgba(0, 229, 255, 0.15);
            --sys-cyan-glow: rgba(0, 229, 255, 0.6);
            --sys-blue: #2962ff;
            --sys-green: #00e676;
            --sys-red: #ff1744;
            --sys-panel: rgba(10, 15, 25, 0.75);
        }

        body { 
            font-family: 'Inter', sans-serif; 
            background-color: var(--sys-bg); 
            color: #f8fafc; 
            overflow-x: hidden;
            -webkit-tap-highlight-color: transparent;
            margin: 0;
        }

        .font-mono-sys { font-family: 'Share Tech Mono', monospace; }
        .hide-scrollbar::-webkit-scrollbar { display: none; }

        /* --- "ALIVE" BACKGROUND EFFECTS --- */
        .system-grid {
            position: fixed;
            inset: 0;
            background: 
                linear-gradient(var(--sys-cyan-dim) 1px, transparent 1px),
                linear-gradient(90deg, var(--sys-cyan-dim) 1px, transparent 1px);
            background-size: 40px 40px;
            z-index: 0;
            pointer-events: none;
            transform: perspective(600px) rotateX(60deg) translateY(-100px) translateZ(-200px);
            animation: gridMove 15s linear infinite;
        }
        
        .particles {
            position: fixed;
            inset: 0;
            z-index: 1;
            pointer-events: none;
            background-image: radial-gradient(circle, var(--sys-cyan) 1px, transparent 1px);
            background-size: 80px 80px;
            opacity: 0.15;
            animation: particleFloat 25s linear infinite;
        }

        .radar-sweep {
            position: fixed;
            width: 200vw;
            height: 200vh;
            top: -50vh;
            left: -50vw;
            background: conic-gradient(from 0deg, transparent 70%, rgba(0, 229, 255, 0.1) 80%, rgba(0, 229, 255, 0.4) 100%);
            z-index: 1;
            pointer-events: none;
            animation: sweep 8s linear infinite;
            border-radius: 50%;
        }

        /* --- KEYFRAMES --- */
        @keyframes gridMove { 0% { background-position: 0 0; } 100% { background-position: 0 40px; } }
        @keyframes particleFloat { 0% { background-position: 0 0; } 100% { background-position: 100px 100px; } }
        @keyframes sweep { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        @keyframes sysAppear { 0% { opacity: 0; transform: scale(0.95) translateY(15px); filter: blur(5px); } 100% { opacity: 1; transform: scale(1) translateY(0); filter: blur(0); } }
        @keyframes pulseGlow { 0% { box-shadow: 0 0 10px var(--sys-cyan-dim); } 50% { box-shadow: 0 0 25px var(--sys-cyan-glow); } 100% { box-shadow: 0 0 10px var(--sys-cyan-dim); } }
        @keyframes redAlert { 0% { border-color: rgba(255, 23, 68, 0.3); } 50% { border-color: rgba(255, 23, 68, 0.8); } 100% { border-color: rgba(255, 23, 68, 0.3); } }

        .animate-sys { animation: sysAppear 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards; }

        /* --- UI COMPONENTS --- */
        .sys-panel {
            background: var(--sys-panel);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(0, 229, 255, 0.2);
            position: relative;
            z-index: 10;
            box-shadow: inset 0 0 30px rgba(0, 229, 255, 0.05), 0 20px 40px rgba(0,0,0,0.8);
        }

        /* Angled Card Cutouts */
        .sys-card {
            background: rgba(5, 10, 20, 0.8);
            border: 1px solid rgba(0, 229, 255, 0.15);
            transition: all 0.2s ease-out;
            position: relative;
            overflow: hidden;
            clip-path: polygon(0 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%);
        }
        
        .sys-card::before {
            content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 4px;
            background: var(--sys-cyan); opacity: 0; transition: opacity 0.2s;
        }

        .sys-card:hover:not(:disabled) {
            border-color: var(--sys-cyan);
            background: rgba(0, 229, 255, 0.08);
            transform: translateX(4px);
            box-shadow: inset 0 0 20px var(--sys-cyan-dim);
        }
        .sys-card:hover:not(:disabled)::before { opacity: 1; }
        .sys-card.selected { border-color: var(--sys-cyan); background: rgba(0, 229, 255, 0.15); box-shadow: inset 0 0 25px var(--sys-cyan-dim); }
        .sys-card.selected::before { opacity: 1; }

        /* Core Button */
        .sys-btn {
            background: linear-gradient(90deg, var(--sys-blue), var(--sys-cyan));
            color: #000;
            font-weight: 900;
            transition: all 0.3s ease;
            text-transform: uppercase;
            position: relative;
            clip-path: polygon(15px 0, 100% 0, 100% calc(100% - 15px), calc(100% - 15px) 100%, 0 100%, 0 15px);
        }
        .sys-btn:hover:not(:disabled) { filter: brightness(1.2); box-shadow: 0 0 30px var(--sys-cyan-glow); transform: scale(1.02); }
        .sys-btn:active:not(:disabled) { transform: scale(0.98); }
        
        /* Locked/Red Button */
        .sys-btn:disabled {
            background: rgba(10, 10, 10, 0.8);
            color: var(--sys-red);
            cursor: not-allowed;
            border: 1px dashed var(--sys-red);
            clip-path: none;
            border-radius: 8px;
            animation: redAlert 2s infinite;
        }

        /* Success Green Box */
        .sys-success-box {
            background: rgba(0, 230, 118, 0.05);
            border: 1px solid var(--sys-green);
            box-shadow: inset 0 0 30px rgba(0, 230, 118, 0.1);
        }
        .sys-btn-green {
            background: var(--sys-green); color: #000;
            box-shadow: 0 0 20px rgba(0, 230, 118, 0.4);
            clip-path: polygon(15px 0, 100% 0, 100% calc(100% - 15px), calc(100% - 15px) 100%, 0 100%, 0 15px);
        }

        /* Glitch Text Effect */
        .glitch { position: relative; }
        .glitch::before, .glitch::after {
            content: attr(data-text); position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        }
        .glitch::before { left: 2px; text-shadow: -1px 0 red; clip: rect(24px, 550px, 90px, 0); animation: glitch-anim-2 3s infinite linear alternate-reverse; }
        .glitch::after { left: -2px; text-shadow: -1px 0 blue; clip: rect(85px, 550px, 140px, 0); animation: glitch-anim 2.5s infinite linear alternate-reverse; }
        @keyframes glitch-anim { 0% { clip: rect(21px, 9999px, 8px, 0); } 100% { clip: rect(62px, 9999px, 99px, 0); } }
        @keyframes glitch-anim-2 { 0% { clip: rect(98px, 9999px, 23px, 0); } 100% { clip: rect(13px, 9999px, 64px, 0); } }

    </style>
</head>
