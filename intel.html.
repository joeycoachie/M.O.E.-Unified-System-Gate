                                    <div className="space-y-5">
                                        <input type="text" placeholder={t.idName} className="w-full bg-slate-900/80 border border-slate-700 focus:border-cyan-500 rounded-xl p-5 text-sm font-bold text-white outline-none transition-all" value={profile.name} onChange={e => setProfile({...profile, name: e.target.value})} />
                                        <input type="email" placeholder={t.idEmail} className="w-full bg-slate-900/80 border border-slate-700 focus:border-cyan-500 rounded-xl p-5 text-sm font-bold text-white outline-none transition-all" value={profile.email} onChange={e => setProfile({...profile, email: e.target.value})} />
                                        <div className="flex gap-2">
                                            <select className="w-[35%] bg-slate-900/80 border border-slate-700 focus:border-cyan-500 rounded-xl p-5 text-cyan-400 text-xs font-black outline-none appearance-none text-center" value={profile.countryCode} onChange={e => setProfile({...profile, countryCode: e.target.value})}>
                                                {COUNTRY_CODES.map(c => <option key={c.code} value={c.code}>{c.label}</option>)}
                                            </select>
                                            <input type="tel" placeholder={t.idPhone} className="w-[65%] bg-slate-900/80 border border-slate-700 focus:border-cyan-500 rounded-xl p-5 text-sm font-bold text-white outline-none transition-all" value={profile.phone} onChange={e => setProfile({...profile, phone: e.target.value})} />
                                        </div>
                                    </div>

                                    <button disabled={!profile.name || !profile.email || !profile.phone} onClick={() => setStep(1)} className="w-full py-5 sys-btn text-xs tracking-[0.1em] mt-8 font-mono-sys">
                                        {t.idBtn}
                                    </button>
                                </div>
                            )}

                            {/* STEP 1 & 2: MULTIPLE CHOICE (SCREENSHOTS 1 & 2) */}
                            {(step === 1 || step === 2) && (
                                <div className="animate-sys flex flex-col pt-4" key={`step-${step}`}>
                                    <h2 className="text-xl md:text-2xl font-bold text-white leading-tight mb-8 text-center px-2">
                                        {step === 1 ? t.q1 : t.q2}
                                    </h2>
                                    
                                    <div className="space-y-4">
                                        {t[`q${step}_opts`].map((opt, num) => (
                                            <button key={num} onClick={() => handleSelect(`q${step}`, opt.title)} className="w-full p-5 sys-card rounded-xl text-left min-h-[70px] flex items-center group">
                                                <span className="font-medium text-white text-[15px] tracking-wide group-hover:text-cyan-400 transition-colors">{opt.title}</span>
                                            </button>
                                        ))}
                                    </div>
                                </div>
                            )}

                            {/* STEP 3: 90-DAY PROMPT & EXPAND (SCREENSHOT 3) */}
                            {step === 3 && (
                                <div className="animate-sys flex flex-col h-full pt-4">
                                    <h2 className="text-xl md:text-2xl font-bold text-white text-center mb-6 px-2">{t.q3}</h2>
                                    
                                    <div className="space-y-3 mb-6">
                                        {t.q3_opts.map((opt, i) => (
                                            <button key={i} onClick={() => handleTemplateSelect(opt)} className={`w-full p-4 sys-card rounded-xl text-left text-sm transition-all ${answers.q3Template === opt ? 'selected text-white font-bold' : 'text-slate-300 font-medium'}`}>
                                                {opt}
                                            </button>
                                        ))}
                                    </div>
                                    
                                    <textarea 
                                        className="flex-1 min-h-[140px] w-full bg-slate-900/80 border border-slate-700 focus:border-cyan-500 rounded-xl p-5 text-sm text-white resize-none mb-4 font-medium leading-relaxed outline-none transition-colors"
                                        placeholder={t.q3_placeholder}
                                        value={answers.q3}
                                        onChange={e => setAnswers({...answers, q3: e.target.value})}
                                    ></textarea>
                                    
                                    <p className="text-[10px] text-cyan-500 font-bold uppercase tracking-widest text-center mb-6 px-4">
                                        {t.q3_sub}
                                    </p>

                                    <button disabled={!isQ3Valid()} onClick={processDiagnostic} className="w-full py-5 sys-btn text-xs tracking-widest mt-auto font-mono-sys">
                                        {!isQ3Valid() ? t.q3_btnLock : t.q3_btnUnlock}
                                    </button>
                                </div>
                            )}

                            {/* STEP 4: BLACK BOX DIAGNOSTIC ILLUSION */}
                            {step === 4 && (
                                <div className="flex flex-col items-center justify-center py-24 animate-sys relative">
                                    <div className="relative w-40 h-40 flex items-center justify-center mb-8">
                                        <div className="absolute inset-0 border-2 border-slate-800 rounded-full"></div>
                                        <div className="absolute inset-0 border-t-2 border-l-2 border-cyan-500 rounded-full animate-spin"></div>
                                        <div className="absolute inset-4 border-b-2 border-r-2 border-blue-500 rounded-full animate-spin" style={{animationDirection: 'reverse', animationDuration: '1.2s'}}></div>
                                        <div className="absolute inset-8 border-t-2 border-green-500 rounded-full animate-spin" style={{animationDuration: '2s'}}></div>
                                        <svg className="text-cyan-400 w-10 h-10 animate-pulse" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
                                    </div>
                                    <p className="text-xs font-black text-cyan-400 tracking-[0.2em] uppercase text-center px-4 font-mono-sys h-8 w-full">
                                        > {loadingText}
                                    </p>
                                </div>
                            )}

                            {/* STEP 5: SUCCESS & NEXT ACTIONS (SCREENSHOT 4) */}
                            {step === 5 && (
                                <div className="animate-sys flex flex-col items-center justify-center h-full pt-4">
                                    
                                    <div className="bg-[#0e2a14] border border-green-600/50 px-5 py-2.5 rounded text-green-400 text-[10px] font-black tracking-[0.1em] mb-8 flex items-center gap-2 shadow-[0_0_20px_rgba(0,230,118,0.2)]">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                        {t.resTag}
                                    </div>

                                    <div className="sys-success-box p-8 md:p-10 rounded-[2rem] w-full mb-8 text-center relative overflow-hidden">
                                        <div className="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-green-500 to-cyan-500"></div>
                                        
                                        <h3 className="text-xs font-black text-green-500 uppercase tracking-[0.3em] mb-4">
                                            {t.resTitle}
                                        </h3>
                                        <h2 className="text-2xl font-black text-white uppercase tracking-tighter mb-6 leading-tight">
                                            {t.resSub}
                                        </h2>
                                        
                                        <div className="bg-black/60 p-5 rounded-2xl border border-green-900/30">
                                            <p className="text-slate-300 text-sm leading-relaxed font-medium">
                                                {t.resDesc}
                                            </p>
                                        </div>
                                    </div>

                                    <p className="text-slate-400 text-xs leading-relaxed text-center mb-8 px-4 font-medium">
                                        {t.resFoot}
                                    </p>

                                    <button onClick={google.script.run} className="w-full py-5 sys-btn-green rounded-2xl font-black uppercase text-xs tracking-widest mt-auto font-mono-sys">
                                        {t.resBtn}
                                    </button>
                                </div>
                            )}

                        </div>
                        
                        {/* Trademark Footer */}
                        <div className="pt-12 mt-auto text-center relative z-10 opacity-30">
                            <div className="text-[10px] font-bold text-slate-500 tracking-[0.3em] uppercase font-mono-sys">
                                © 2026 THE M.O.E. GROUP<br/>
                                <span className="text-[8px] tracking-[0.4em] mt-1 block opacity-80">{t.tagline}</span>
                            </div>
                        </div>
                    </div>
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
